<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>SweetCrumbs Bakery</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@400;600;700&display=swap" rel="stylesheet">

    <!-- Material Icons -->
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">

    <!-- Materialize CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">

    <style>
        body {
            font-family: 'Josefin Sans', sans-serif;
        }
        .brand-logo {
            font-weight: 700;
        }
        .parallax-container {
            height: 500px;
        }
        section {
            padding: 60px 0;
        }
    </style>
</head>

<body>

<!-- NAVBAR -->
<nav class="brown darken-3">
    <div class="nav-wrapper container">
        <a href="#" class="brand-logo">SweetCrumbs</a>
        <a href="#" data-target="mobile-menu" class="sidenav-trigger">
            <i class="material-icons">menu</i>
        </a>

        <ul class="right hide-on-med-and-down">
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#services">Services</a></li>
            <li><a href="#gallery">Gallery</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </div>
</nav>

<!-- MOBILE MENU -->
<ul class="sidenav" id="mobile-menu">
    <li><a href="#home">Home</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#services">Services</a></li>
    <li><a href="#gallery">Gallery</a></li>
    <li><a href="#contact">Contact</a></li>
</ul>

<!-- HERO -->
<div id="home" class="parallax-container">
    <div class="parallax">
        <img src="https://images.pexels.com/photos/1756062/pexels-photo-1756062.jpeg?auto=compress&cs=tinysrgb&w=1600">
    </div>
    <div class="container center-align white-text" style="margin-top:180px;">
        <h2>Freshly Baked Happiness</h2>
        <p class="flow-text">Delicious cakes, artisan bread & pastries made daily.</p>
        <a href="#services" class="btn brown lighten-1 waves-effect waves-light">Explore Menu</a>
    </div>
</div>

<!-- ABOUT -->
<section id="about" class="container">
    <div class="row">
        <div class="col s12 m6">
            <img class="responsive-img z-depth-2"
                 src="https://images.pexels.com/photos/230743/pexels-photo-230743.jpeg?auto=compress&cs=tinysrgb&w=1600">
        </div>
        <div class="col s12 m6">
            <h4>About Our Bakery</h4>
            <p>
                At SweetCrumbs, we combine tradition with creativity.
                Every product is handcrafted using premium ingredients.
                We believe baking is love made edible.
            </p>
        </div>
    </div>
</section>

<!-- SERVICES -->
<section id="services" class="brown lighten-5">
    <div class="container">
        <h4 class="center-align">Our Specialties</h4>
        <div class="row">

            <div class="col s12 m4">
                <div class="card">
                    <div class="card-image">
                        <img src="https://images.pexels.com/photos/1775035/pexels-photo-1775035.jpeg?auto=compress&cs=tinysrgb&w=1600">
                    </div>
                    <div class="card-content center-align">
                        <span class="card-title">Custom Cakes</span>
                        <p>Perfect for birthdays & celebrations.</p>
                    </div>
                </div>
            </div>

            <div class="col s12 m4">
                <div class="card">
                    <div class="card-image">
                        <img src="https://images.pexels.com/photos/1028704/pexels-photo-1028704.jpeg?auto=compress&cs=tinysrgb&w=1600">
                    </div>
                    <div class="card-content center-align">
                        <span class="card-title">Artisan Bread</span>
                        <p>Fresh sourdough & whole grain breads.</p>
                    </div>
                </div>
            </div>

            <div class="col s12 m4">
                <div class="card">
                    <div class="card-image">
                        <img src="https://images.pexels.com/photos/8027652/pexels-photo-8027652.jpeg?auto=compress&cs=tinysrgb&w=1600">
                    </div>
                    <div class="card-content center-align">
                        <span class="card-title">Pastries</span>
                        <p>Flaky croissants & sweet delights.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- GALLERY -->
<section id="gallery" class="container">
    <h4 class="center-align">Gallery</h4>
    <div class="row">
        <div class="col s12 m4">
            <img class="responsive-img z-depth-1"
                 src="https://images.pexels.com/photos/14565951/pexels-photo-14565951.jpeg?auto=compress&cs=tinysrgb&w=1600">
        </div>
        <div class="col s12 m4">
            <img class="responsive-img z-depth-1"
                 src="https://images.pexels.com/photos/14565950/pexels-photo-14565950.jpeg?auto=compress&cs=tinysrgb&w=1600">
        </div>
        <div class="col s12 m4">
            <img class="responsive-img z-depth-1"
                 src="https://images.pexels.com/photos/5945565/pexels-photo-5945565.jpeg?auto=compress&cs=tinysrgb&w=1600">
        </div>
    </div>
</section>

<!-- CONTACT -->
<section id="contact" class="brown lighten-5">
    <div class="container">
        <h4 class="center-align">Contact Us</h4>

        <div class="row">
            <form class="col s12">

                <div class="row">
                    <div class="input-field col s12 m6">
                        <input id="name" type="text" required>
                        <label for="name">Name</label>
                    </div>

                    <div class="input-field col s12 m6">
                        <input id="email" type="email" required>
                        <label for="email">Email</label>
                    </div>
                </div>

                <div class="row">
                    <div class="input-field col s12">
                        <textarea id="message" class="materialize-textarea" required></textarea>
                        <label for="message">Message</label>
                    </div>
                </div>

                <div class="center-align">
                    <button class="btn brown darken-2 waves-effect waves-light" type="submit">
                        Send Message
                    </button>
                </div>

            </form>
        </div>
    </div>
</section>

<!-- FOOTER -->
<footer class="page-footer brown darken-3">
    <div class="container center-align">
        © 2026 SweetCrumbs Bakery | Made with Materialize
    </div>
</footer>

<!-- Materialize JS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var sidenav = document.querySelectorAll('.sidenav');
    M.Sidenav.init(sidenav);

    var parallax = document.querySelectorAll('.parallax');
    M.Parallax.init(parallax);
});
</script>

</body>
</html>
